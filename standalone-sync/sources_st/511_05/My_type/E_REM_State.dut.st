TYPE E_REM_State :
(
    INIT,              (* Начальная инициализация и сброс регистров при запуске *)
    OPERATING,         (* Нормальный циклический режим обработки физических данных *)
    RESET_LOGIC,       (* Шаг удержания команды сброса сумматора *)
